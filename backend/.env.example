# ============================================
# TuringMate Backend - Environment Variables
# ============================================

# Application
APP_NAME=TuringMate
DEBUG=True

# Database (MySQL)
DATABASE_URL=mysql+pymysql://turingmate:turingmate@localhost:3306/turingmate

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM - Model Gateway
DEFAULT_LLM_MODEL=deepseek

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI (GPT-4o)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Qwen (通义千问)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# RAG Configuration
EMBEDDING_MODEL=text2vec-base-chinese
CHROMA_PERSIST_DIR=./data/chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# COS (腾讯云对象存储)
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=turingmate-bucket
COS_REGION=ap-shanghai
